# victron-bm-webui environment variables
# Copy this file to .env and adjust values as needed.
#
# This file contains infrastructure settings and secrets.
# Application behavior (alarm thresholds, intervals, notifications)
# is configured in config/config.yaml.

# ── General ──────────────────────────────────────────────
TZ=Europe/Warsaw
APP_PORT=80

# ── Device / BLE ─────────────────────────────────────────
# Mock mode (true = simulated data for development)
DEVICE_MOCK=true

# Real device credentials (required when DEVICE_MOCK=false)
# Get the advertisement key from VictronConnect app.
# BLE_MAC_ADDRESS=D8:AB:02:0C:FE:A4
# BLE_ADV_KEY=your_advertisement_key_hex

# ── BLE Docker mode ─────────────────────────────────────
# Uncomment to enable real BLE (adds network_mode: host + D-Bus).
# Required on Linux when DEVICE_MOCK=false.
# COMPOSE_FILE=docker-compose.yml:docker-compose.ble.yml

# ── SMTP (email notifications) ──────────────────────────
# SMTP_ENABLED=true
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=user
# SMTP_PASSWORD=secret
# SMTP_SENDER_NAME=Victron BM Monitor
# SMTP_SENDER_EMAIL=victron@example.com
# SMTP_RECIPIENTS=user1@example.com,user2@example.com

# ── Pushover (push notifications) ──────────────────────
# PUSHOVER_ENABLED=false
# PUSHOVER_TOKEN=your_app_token
# PUSHOVER_USER=your_user_key

# ── Notification Priorities (-2 to 2) ──────────────────
# Default is 0 (Normal). 1 = High (bypasses quiet hours), 2 = Emergency.
# PRIORITY_AC_POWER_LOST=1
# PRIORITY_AC_POWER_RESTORED=0
# PRIORITY_LOW_VOLTAGE=1
# PRIORITY_HIGH_VOLTAGE=1
# PRIORITY_LOW_SOC=1
# PRIORITY_HIGH_TEMPERATURE=1
# PRIORITY_LOW_TEMPERATURE=1
# PRIORITY_DEVICE_OFFLINE=1
# PRIORITY_DEVICE_ONLINE=0
# PRIORITY_WATCHDOG_RESTART=1
