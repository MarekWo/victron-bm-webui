# victron-bm-webui environment variables
# Copy this file to .env and adjust values as needed.

# Timezone
TZ=Europe/Warsaw

# Host port mapping (container always listens on 80 internally)
# Ignored when using network_mode: host (BLE mode)
APP_PORT=80

# --- Device / BLE ---
# Set DEVICE_MOCK=false and provide BLE credentials for real device
DEVICE_MOCK=true
# BLE_MAC_ADDRESS=D8:AB:02:0C:FE:A4
# BLE_ADV_KEY=your_advertisement_key_hex

# --- BLE production mode ---
# Uncomment the line below to enable BLE (adds network_mode: host + D-Bus access)
# COMPOSE_FILE=docker-compose.yml:docker-compose.ble.yml

# --- SMTP configuration ---
# Set SMTP_ENABLED=true to activate email notifications.
# SMTP_ENABLED=true
# SMTP_SERVER=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USERNAME=user
# SMTP_PASSWORD=secret
# SMTP_SENDER_NAME=Victron BM Monitor
# SMTP_SENDER_EMAIL=victron@example.com
# SMTP_RECIPIENTS=user1@example.com,user2@example.com
