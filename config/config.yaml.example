# victron-bm-webui configuration
# Copy this file to config.yaml and adjust values as needed.
#
# Note: Device credentials (MAC, advertisement key) and SMTP settings
# are configured in .env, not here. See .env.example for details.

# Device display name
device:
  name: "BMV-712 Smart"

# BLE polling settings
ble:
  poll_interval_seconds: 10   # How often to read BLE data

# Database settings
database:
  path: "/data/victron-bm.db"
  retention_days: 30          # Delete readings older than this

# Alarm thresholds (set to null to disable individual alarms)
alarms:
  low_voltage: 11.5           # Volts
  high_voltage: 15.0          # Volts
  low_soc: 20.0               # Percent
  high_temperature: 45.0      # Celsius
  low_temperature: 0.0        # Celsius
  ac_power_voltage: null      # Volts - AC power lost if voltage drops below (e.g., 13.60)

# Notification settings (which events trigger emails)
notifications:
  alarm_triggered: true       # Device alarm state changes
  alarm_cleared: true         # Device alarm clears
  threshold_exceeded: true    # App-defined threshold exceeded
  device_offline: true        # No BLE data for >5 minutes
  device_online: true         # BLE data resumes after offline
  ac_power_lost: true         # Voltage drops below ac_power_voltage threshold
  ac_power_restored: true     # Voltage returns above ac_power_voltage threshold
